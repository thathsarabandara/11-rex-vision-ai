# ─── Application ────────────────────────────────────────────────────────────
APP_NAME=rex-vision-ai
APP_ENV=development
APP_PORT=8011

# ─── Database (MySQL 8) ──────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=rex
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=rex_vision_ai_db
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=11

# ─── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=rex-vision-ai-producer

# ─── Qdrant ─────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_FACE_COLLECTION=rex_face_embeddings
QDRANT_GESTURE_COLLECTION=rex_gesture_embeddings
QDRANT_SCENE_COLLECTION=rex_scene_embeddings
QDRANT_MEMORY_COLLECTION=rex_visual_memory

# ─── MinIO ──────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=rex_minio_user
MINIO_SECRET_KEY=rex_minio_password
MINIO_SECURE=false
MINIO_BUCKET=rex-vision-ai
DATASET_PREFIX=datasets/

# ─── AI Models ──────────────────────────────────────────────────────────────
DEVICE=cpu
OBJECT_MODEL_PATH=yolov8n.pt
FACE_MODEL_NAME=buffalo_sc
EXPRESSION_MODEL_PATH=models/expression.onnx
VISION_INPUT_WIDTH=640
VISION_INPUT_HEIGHT=480
VISION_MAX_FPS=20

# ─── Detection Thresholds ────────────────────────────────────────────────────
OBJECT_CONFIDENCE_THRESHOLD=0.45
OBJECT_IOU_THRESHOLD=0.5
FACE_KNOWN_THRESHOLD=0.75
FACE_UNCERTAIN_THRESHOLD=0.55
EXPRESSION_CONFIDENCE_THRESHOLD=0.6
GESTURE_CONFIDENCE_THRESHOLD=0.7
GESTURE_STABILITY_FRAMES=5

# ─── Feature Flags ──────────────────────────────────────────────────────────
OBJECT_DETECTION_ENABLED=true
FACE_DETECTION_ENABLED=true
FACE_RECOGNITION_ENABLED=true
EXPRESSION_ESTIMATION_ENABLED=false
PERSON_TRACKING_ENABLED=true
GESTURE_DETECTION_ENABLED=false
SCENE_UNDERSTANDING_ENABLED=true
SCENE_DESCRIPTION_ENABLED=true
VISUAL_OBSTACLE_ENABLED=false
LOW_LIGHT_DETECTION_ENABLED=true
INCIDENT_CAPTURE_ENABLED=false

# ─── Auth & Service Integration ─────────────────────────────────────────────
USER_JWT_SECRET_KEY=replace_with_real_secret
USER_JWT_ALGORITHM=HS256
USER_JWT_ISSUER=rex-auth-service
USER_JWT_AUDIENCE=rex-platform
INTERNAL_SERVICE_TOKEN=replace_with_real_internal_token
ROBOT_SERVICE_URL=http://localhost:8003
OWNERSHIP_CACHE_TTL_SECONDS=300
EVENT_COOLDOWN_SECONDS=10
